# ---------------------------------------------------------------------------
# Helper SMACH states added during F2/F3/F4 robustness rework.
# ---------------------------------------------------------------------------

# Mower FW (STM32 STMmowerROSControll) status strings:
#   INIT, OFF, READY, RUN, HOME, CHANGE_HEIGHT, ERR, BLOCKED, TEMP
MOWER_ERROR_STATES = ('ERR', 'BLOCKED', 'TEMP')


class WaitForMowerStatus(smach.State):
    """Wait until /mower/status reaches a target string with timeout + error detection.

    Outcomes:
      - 'reached'  : status matched ``target`` (or one of ``targets``)
      - 'error'    : FW reported an error state (ERR/BLOCKED/TEMP)
      - 'timeout'  : did not reach target within ``timeout`` seconds
      - 'preempted': SMACH preempt requested
    """

    def __init__(self, targets, timeout=30.0, extra_check=None):
        smach.State.__init__(self,
                             outcomes=['reached', 'error', 'timeout', 'preempted'],
                             input_keys=[], output_keys=[])
        if isinstance(targets, str):
            targets = (targets,)
        self.targets = tuple(targets)
        self.timeout = float(timeout)
        # Optional extra predicate: callable(msg) -> True if condition met.
        self.extra_check = extra_check

    def execute(self, userdata):
        deadline = rospy.Time.now() + rospy.Duration(self.timeout)
        while not rospy.is_shutdown() and rospy.Time.now() < deadline:
            if self.preempt_requested():
                self.service_preempt()
                return 'preempted'
            try:
                msg = rospy.wait_for_message('/mower/status', Mower, timeout=1.0)
            except rospy.ROSException:
                continue
            if msg.status in MOWER_ERROR_STATES:
                rospy.logwarn('[WaitForMowerStatus] FW error state: %s', msg.status)
                return 'error'
            if msg.status in self.targets:
                if self.extra_check is None or self.extra_check(msg):
                    return 'reached'
        rospy.logwarn('[WaitForMowerStatus] timeout (%.1fs) waiting for %s',
                      self.timeout, self.targets)
        return 'timeout'


class WaitForTopic(smach.State):
    """Generic timeout-bounded wait for a single message that satisfies ``predicate``.

    Outcomes:
      - 'received' : predicate returned True
      - 'timeout'  : timeout expired
      - 'preempted': SMACH preempt requested
    """

    def __init__(self, topic, msg_type, predicate, timeout=30.0,
                 output_keys=None, on_match=None):
        smach.State.__init__(self,
                             outcomes=['received', 'timeout', 'preempted'],
                             input_keys=[],
                             output_keys=output_keys or [])
        self.topic = topic
        self.msg_type = msg_type
        self.predicate = predicate
        self.timeout = float(timeout)
        # on_match(userdata, msg) called once predicate is True (e.g. to copy msg into userdata).
        self.on_match = on_match

    def execute(self, userdata):
        deadline = rospy.Time.now() + rospy.Duration(self.timeout)
        while not rospy.is_shutdown() and rospy.Time.now() < deadline:
            if self.preempt_requested():
                self.service_preempt()
                return 'preempted'
            remaining = (deadline - rospy.Time.now()).to_sec()
            if remaining <= 0:
                break
            try:
                msg = rospy.wait_for_message(self.topic, self.msg_type,
                                             timeout=min(1.0, remaining))
            except rospy.ROSException:
                continue
            if self.predicate(msg):
                if self.on_match is not None:
                    try:
                        self.on_match(userdata, msg)
                    except Exception as e:
                        rospy.logwarn('[WaitForTopic %s] on_match raised: %s', self.topic, e)
                return 'received'
        rospy.logwarn('[WaitForTopic] timeout (%.1fs) on %s', self.timeout, self.topic)
        return 'timeout'


class RetryLimitedAction(smach.State):
    """Reusable retry counter; increments userdata key and decides retry vs give-up.

    Used as a tiny gate after a failing action / get_path:
      - increments ``userdata.<counter_key>``
      - returns 'retry' until counter reaches ``max_retries``
      - then resets counter and returns 'give_up'
    """

    def __init__(self, counter_key, max_retries=3):
        smach.State.__init__(self,
                             outcomes=['retry', 'give_up', 'preempted'],
                             input_keys=[counter_key],
                             output_keys=[counter_key])
        self.counter_key = counter_key
        self.max_retries = int(max_retries)

    def execute(self, userdata):
        if self.preempt_requested():
            self.service_preempt()
            return 'preempted'
        current = int(getattr(userdata, self.counter_key, 0) or 0) + 1
        setattr(userdata, self.counter_key, current)
        if current >= self.max_retries:
            rospy.logwarn('[RetryLimitedAction] %s reached %d retries; giving up',
                          self.counter_key, current)
            setattr(userdata, self.counter_key, 0)
            return 'give_up'
        rospy.loginfo('[RetryLimitedAction] %s retry %d/%d',
                      self.counter_key, current, self.max_retries)
        return 'retry'


class GetZoneData(smach.State):
    def __init__(self):
        smach.State.__init__(self, outcomes=['available', 'failed', 'preempted', 'skip_zone'],
                             input_keys=['program', 'zone_cut_height', 'zone_rpm', 'index', 'zone_name',
                                         'zone_start_pose', 'paths', 'unfinished_active', 'unfinished_zone', 'unfinished_path', 'path_window_start_index', 'unfinished_window'],
                             output_keys=['zone_cut_height', 'zone_rpm', 'zone_name',
                                          'zone_start_pose', 'paths', 'controller', 'unfinished_active', 'unfinished_zone', 'unfinished_path', 'path_window_start_index',
                                          'retry_get_path_to_start',
                                          'retry_get_path_to_begin',
                                          'retry_exe_to_begin',
                                          'retry_planner'])

    def execute(self, userdata):
        rospy.loginfo('[{}]Getting zone data - state GET_ZONE_DATA'.format(rospy.get_caller_id()))
        # Reset all retry counters when entering a new zone.
        userdata.retry_get_path_to_start = 0
        userdata.retry_get_path_to_begin = 0
        userdata.retry_exe_to_begin = 0
        userdata.retry_planner = 0
        
        current_zone_name = userdata.program.zone_list[userdata.index].name

        if userdata.unfinished_active and current_zone_name != userdata.unfinished_zone:
            rospy.loginfo('[{}]Skipping zone {} to resume at {}'.format(rospy.get_caller_id(), current_zone_name, userdata.unfinished_zone))
            return 'skip_zone'
        
        if userdata.unfinished_active and current_zone_name == userdata.unfinished_zone:
            rospy.loginfo('[{}]Resuming at unfinished zone ################: {} path: {}'.format(rospy.get_caller_id(), userdata.unfinished_zone, userdata.unfinished_path))

        userdata.zone_cut_height = userdata.program.zone_list[userdata.index].cut_height
        userdata.zone_rpm = userdata.program.zone_list[userdata.index].rpm
        userdata.zone_name = userdata.program.zone_list[userdata.index].name
        userdata.paths = userdata.program.zone_list[userdata.index].paths
        if userdata.unfinished_active and current_zone_name == userdata.unfinished_zone:
            # Resume: navigate directly to the pose where mowing was interrupted.
            # path_window_start_index indexes the segmentized (~3 cm spacing) path,
            # so we must segmentize the raw path the same way GetPathData does.
            resume_path_idx = int(userdata.unfinished_path)
            resume_window = int(userdata.unfinished_window) if userdata.unfinished_window else 0
            raw_resume_path = userdata.paths[resume_path_idx]
            try:
                segmented = segmentize_raw_path(raw_resume_path)
                if not segmented.poses:
                    raise ValueError("segmented path is empty")
                resume_window = max(0, min(resume_window, len(segmented.poses) - 1))
                userdata.zone_start_pose = segmented.poses[resume_window]
                rospy.loginfo('[{}]Resume: navigating directly to path {} window {} (segmented poses={})'.format(
                    rospy.get_caller_id(), resume_path_idx, resume_window, len(segmented.poses)))
            except Exception as e:
                rospy.logwarn('[{}]Resume pose computation failed ({}); falling back to raw path[{}].poses[0]'.format(
                    rospy.get_caller_id(), e, resume_path_idx))
                userdata.zone_start_pose = raw_resume_path.poses[0]
        else:
            userdata.zone_start_pose = userdata.program.zone_list[userdata.index].paths[0].poses[0]
        userdata.controller = 'base_local_planner/TrajectoryPlannerROS'
        # print(userdata.zone_name)
        # print(userdata.zone_cut_height)
        show_map_planner_pub = rospy.Publisher("/web_plan/show_map_layer", String, latch=True, queue_size=1)
        show_map_planner_pub.publish(String("SMACH|MAP|FULL"))
        rospy.sleep(3)

        if self.preempt_requested():
            self.service_preempt()

            return 'preempted'
        return 'available'


class GetPathData(smach.State):
    def __init__(self, save_prg_pub):
        smach.State.__init__(self, outcomes=['available', 'preempted', 'skip_path'],
                             input_keys=['program', 'zone_cut_height', 'zone_rpm', 'index', 'zone_name', 'path_planner',
                                         'zone_start_pose', 'path_plan', 'index_path', 'paths', 'path_start_pose',
                                         'path', 'final_pose', 'unfinished_active', 'unfinished_zone', 'unfinished_path',
                                         'unfinished_window', 'path_window_start_index'],
                             output_keys=['program', 'zone_cut_height', 'zone_rpm', 'zone_name', 'zone_start_pose', 'path_planner',
                                          'path_plan', 'paths', 'path_start_pose', 'path', 'final_pose',
                                          'unfinished_active', 'unfinished_zone', 'unfinished_path', 'unfinished_window',
                                          'path_window_start_index',
                                          'retry_get_path_to_begin',
                                          'retry_exe_to_begin',
                                          'retry_planner'])
        self.save_prg_pub = save_prg_pub
        # Reset path-level retry counters at construction time so the very first
        # path of a fresh program also starts with a clean slate (counters get
        # reset again per-path inside execute()).

    def _reset_path_retries(self, userdata):
        userdata.retry_get_path_to_begin = 0
        userdata.retry_exe_to_begin = 0
        userdata.retry_planner = 0
    def path_to_polygon(self, path):
        # create shapely polygon from path poses
        polygon = geometry.LinearRing([[pose.pose.position.x, pose.pose.position.y] for pose in path.poses])
        polygon = shapely.remove_repeated_points(polygon)
        return polygon

    def path_to_multiline(self, path):
        # create shapely multiline string from path poses
        multiline = geometry.MultiLineString(
            [[[pose.pose.position.x, pose.pose.position.y] for pose in path.poses]])
        return multiline

    def path_to_line(self, path):
        # create shapely multiline string from path poses
        line = geometry.LineString(
            [[pose.pose.position.x, pose.pose.position.y] for pose in path.poses])
        return line

    def direction(self, line):
        # point_2.x - point_1.x, point_2.y - point_1.y)
        x = line[1][0] - line[0][0]
        y = line[1][1] - line[0][1]
        diagonal = math.sqrt(x ** 2 + y ** 2)
        if y < 0:
            if x >= 0:
                angle = math.asin(y / diagonal)
            else:
                angle = math.acos(x / diagonal) * -1
        else:
            if x >= 0:
                angle = math.asin(y / diagonal)
            else:
                angle = math.acos(x / diagonal)
        return angle

    def execute(self, userdata):
        rospy.loginfo('[{}]Getting path data - state GET_PATH_DATA'.format(rospy.get_caller_id()))
        # Reset retry counters at the start of every new path so a single
        # transient failure earlier in the run does not shorten our retry budget.
        self._reset_path_retries(userdata)
        # Check if resumed program and skip to resumed path 
        if userdata.unfinished_active and str(userdata.index_path) != userdata.unfinished_path:
            rospy.loginfo('[{}]Skipping path {} to resume at {}'.format(rospy.get_caller_id(), userdata.index_path, userdata.unfinished_path))
            return 'skip_path'
        
        # Continue as normal if resumed path
        path = userdata.paths[userdata.index_path]
        userdata.path_start_pose = path.poses[0] 
        userdata.path_planner = path
        # userdata.path_start_pose = path.poses[0]

        # Save current zone and path as last failed to resume later will be overwritten at  
        # the end of the program if successful
        # userdata.program.last_result = f'failed: on_path-{userdata.zone_name}-{userdata.index_path}'
        userdata.program.last_result = f'failed: on_path-{userdata.zone_name}-{userdata.index_path}-{userdata.path_window_start_index}'
        self.save_prg_pub.publish(userdata.program)

        show_map_planner_pub = rospy.Publisher("/web_plan/show_map_layer", String, latch=True, queue_size=1)
        show_map_planner_pub.publish(String("SMACH|ZONE|{}".format(userdata.zone_name)))
        line = geometry.LineString([[path.poses[0].pose.position.x, path.poses[0].pose.position.y],
                                    [path.poses[-1].pose.position.x, path.poses[-1].pose.position.y]])

        # print("Line length: {}".format(line.length))
        segmentize_distance = 0.03
        # segmentize_distance = 1.5

        # Coverage outline path
        if line.length == 0:
            # print("Outline path")
            start_offset = 0.18
            start_poses_offset = int(round(start_offset / segmentize_distance))
            path_new = Path()
            path_new.header = path.header
            polygon = self.path_to_polygon(path)
            for n in range(0, len(polygon.coords) - 1):
                line = geometry.LineString([[polygon.coords[n][0], polygon.coords[n][1]],
                                            [polygon.coords[n + 1][0], polygon.coords[n + 1][1]]])
                angle = self.direction(line.coords)
                line = line.segmentize(segmentize_distance)
                for point in line.coords:
                    pose = PoseStamped()
                    pose.header.frame_id = "map"
                    pose.header.stamp = rospy.Time.now()
                    pose.pose.position.x = point[0]
                    pose.pose.position.y = point[1]
                    pose.pose.position.z = 0.0
                    pose.pose.orientation = Quaternion(
                        *(kdl.Rotation.RPY(0, 0, angle).GetQuaternion()))
                    path_new.poses.append(pose)
            path_new.poses = path_new.poses[0:-start_poses_offset]
            path_new.poses = path_new.poses[start_poses_offset:]
            path = path_new
            userdata.path_start_pose = path.poses[0]
            userdata.final_pose = path.poses[-1]

        # Coverage infill path
        else:
            # print("Coverage path")
            line = self.path_to_line(path)
            path_new = Path()
            path_new.header.frame_id = "map"
            path_new.header.stamp = rospy.Time.now()

            line = line.segmentize(segmentize_distance)
            for pose_id in range(0, len(line.coords) - 1):
                angle = self.direction([[line.coords[pose_id][0], line.coords[pose_id][1]],
                                       [line.coords[pose_id + 1][0], line.coords[pose_id + 1][1]]])
                pose = PoseStamped()
                pose.header.frame_id = "map"
                pose.header.stamp = rospy.Time.now()
                pose.pose.position.x = line.coords[pose_id][0]
                pose.pose.position.y = line.coords[pose_id][1]
                pose.pose.position.z = 0.0
                pose.pose.orientation = Quaternion(
                    *(kdl.Rotation.RPY(0, 0, angle).GetQuaternion()))
                path_new.poses.append(pose)
            path = path_new

        # If resumed program on this path, set the start pose to the unfinished window
        if userdata.unfinished_active and str(userdata.index_path) == userdata.unfinished_path:
            rospy.loginfo('[{}]Resuming at unfinished path ################: {}'.format(rospy.get_caller_id(), userdata.unfinished_path))
            rospy.loginfo(f'[{rospy.get_caller_id()}] Path poses: {len(path.poses)}  unfinished_window: {userdata.unfinished_window}  index_path: {userdata.index_path}')
            userdata.path_window_start_index = userdata.unfinished_window
            userdata.path_start_pose = path.poses[userdata.path_window_start_index]
            userdata.unfinished_active = False
        
        # publish current path
        pub_current_path = rospy.Publisher('/test_path', Path, latch=True, queue_size=1)
        pub_current_path.publish(path)
        userdata.path = path

        if self.preempt_requested():
            self.service_preempt()
            return 'preempted'
        return 'available'


class CheckDistance(smach.State):
    def __init__(self):
        smach.State.__init__(self, outcomes=['on_place', 'exe_path', 'preempted'],
                             input_keys=['path_cost'],
                             output_keys=['path_cost'])

    def execute(self, userdata):
        rospy.loginfo('[{}]Checking path distance - state CHECK_DISTANCE'.format(rospy.get_caller_id()))
        # print("Path distance: {}".format(userdata.path_cost))
        if self.preempt_requested():
            self.service_preempt()
            return 'preempted'
        if userdata.path_cost <= 0.2:
            return 'on_place'
        else:
            return 'exe_path'


class WindowPlannerPath(smach.State):
    """Produce the next chunk of a long mowing path, anchored to the robot's
    current TF position.

    Behaviour:
      * Looks up ``map -> base_link`` and finds the nearest pose in
        ``userdata.path``; this index is the start of the new chunk.
      * The chunk runs from that index to ``current_index + window_size`` (or
        the end of the path).
      * ``userdata.path_window_start_index`` is updated to the *current* index
        \u2014 i.e. the last known good location \u2014 so a resume after a crash
        restarts very close to where mowing was interrupted.
      * Returns ``finished`` once the robot is within ``end_tolerance`` metres
        of the last pose, or when the chunk would be empty.
      * Falls back to a fixed-step advance (legacy behaviour) when TF is
        unavailable so we still make forward progress.
    """

    def __init__(self, save_prg_pub):
        smach.State.__init__(self, outcomes=['available', 'finished', 'preempted'],
                             input_keys=['path', 'path_window_start_index', 'zone_name',
                                         'index_path', 'program'],
                             output_keys=['path_chunk', 'path_window_start_index', 'program',
                                          'path_chunk_trim_count'])
        self.window_size = 200
        self.fallback_step = 100   # used only when TF is unavailable
        self.end_tolerance = 0.4   # m; "we are at the goal pose" threshold
        self.tail_indices = 5       # treat the last few poses as "near the end"
        self.save_prg_pub = save_prg_pub

    def execute(self, userdata):
        rospy.loginfo('[{}]Windowing path - state WINDOW_PLANNER_PATH'.format(rospy.get_caller_id()))
        if self.preempt_requested():
            self.service_preempt()
            return 'preempted'

        userdata.path_chunk_trim_count = 0
        full_path = userdata.path
        if not full_path or not full_path.poses:
            userdata.path_window_start_index = 0
            return 'finished'

        prev_index = int(userdata.path_window_start_index or 0)
        n = len(full_path.poses)

        # Anchor the next chunk to the robot's current position when TF is up.
        robot_xy = get_robot_xy_in_map()
        if robot_xy is not None:
            current_index = nearest_pose_index(full_path, robot_xy[0], robot_xy[1],
                                               hint_index=prev_index)
            # Never roll backwards \u2014 if the planner thinks we are upstream of the
            # last logged position, prefer the logged position so we don't replay
            # already-mowed strip.
            current_index = max(current_index, prev_index)

            # Are we close enough to the final pose to declare the path done?
            last_p = full_path.poses[-1].pose.position
            dist_to_end = math.hypot(robot_xy[0] - last_p.x, robot_xy[1] - last_p.y)
            if current_index >= n - self.tail_indices and dist_to_end < self.end_tolerance:
                rospy.loginfo('[WINDOW_PLANNER_PATH] reached end of path '
                              '(idx=%d/%d, dist=%.2fm)', current_index, n, dist_to_end)
                userdata.path_window_start_index = 0
                return 'finished'
        else:
            # TF unavailable: behave like the original fixed-step planner.
            rospy.logwarn_throttle(5.0,
                                   '[WINDOW_PLANNER_PATH] TF map->base_link unavailable; '
                                   'falling back to fixed-step windowing.')
            current_index = prev_index
            if current_index >= n:
                userdata.path_window_start_index = 0
                return 'finished'

        end_index = min(current_index + self.window_size, n)
        path_chunk = Path()
        path_chunk.header = full_path.header
        path_chunk.poses = full_path.poses[current_index:end_index]

        if not path_chunk.poses:
            userdata.path_window_start_index = 0
            return 'finished'

        userdata.path_chunk = path_chunk

        # Save *current* (last-known-good) index so resume picks up here, not
        # one window ahead. For the fallback path advance the index by
        # fallback_step to guarantee forward motion across iterations.
        if robot_xy is not None:
            userdata.path_window_start_index = current_index
        else:
            userdata.path_window_start_index = min(current_index + self.fallback_step, n)

        userdata.program.last_result = (
            f'failed: on_path-{userdata.zone_name}-{userdata.index_path}-{current_index}'
        )

        return 'available'


class TrimAndRetry(smach.State):
    """Progressively trims poses from the end of a path chunk when CHECK_PLANNER_PATH fails.

    Useful when GPS drift creates a phantom obstacle near the end of a short chunk.
    After max_trims attempts the state bypasses the check and lets the executor
    handle any real obstacle via RECOVERY_PLANNER.
    """
    def __init__(self):
        smach.State.__init__(self,
                             outcomes=['retry', 'bypass_check', 'preempted'],
                             input_keys=['path_chunk', 'path_chunk_trim_count'],
                             output_keys=['path_chunk', 'path_chunk_trim_count'])
        self.trim_step = 15    # poses trimmed per attempt (~45 cm at 3 cm spacing)
        self.max_trims = 5     # after 5 trims (~2.25 m) give up checking and execute
        self.min_chunk_size = 20  # never send a chunk shorter than this

    def execute(self, userdata):
        if self.preempt_requested():
            self.service_preempt()
            return 'preempted'

        trim_count = userdata.path_chunk_trim_count
        chunk = userdata.path_chunk

        if trim_count >= self.max_trims or len(chunk.poses) <= self.min_chunk_size:
            rospy.loginfo('[{}]TrimAndRetry: max trims reached ({}), bypassing check'.format(
                rospy.get_caller_id(), trim_count))
            return 'bypass_check'

        trimmed = Path()
        trimmed.header = chunk.header
        trimmed.poses = chunk.poses[:-self.trim_step]

        if not trimmed.poses:
            return 'bypass_check'

        userdata.path_chunk = trimmed
        userdata.path_chunk_trim_count = trim_count + 1
        rospy.loginfo('[{}]TrimAndRetry: trimmed {} poses, chunk now {} poses (attempt {}/{})'.format(
            rospy.get_caller_id(), self.trim_step, len(trimmed.poses),
            trim_count + 1, self.max_trims))
        return 'retry'


def wait_for_mbf():
    client = actionlib.SimpleActionClient("/move_base_flex/move_base", mbf_msgs.MoveBaseAction)
    available = client.wait_for_server(rospy.Duration(30))
    if not available:
        rospy.logwarn("Move Base Flex is not available")
    else:
        rospy.loginfo("Move Base Flex is ready")
    return available


def main():
    rospy.init_node('mower_unit_smach')
    pub_smach_status = rospy.Publisher('/mower_smach/status', String, latch=True, queue_size=1)
    pub_log_info = rospy.Publisher('/nextion/log_info', String, queue_size=10, latch=True)
    pub_active_prg = rospy.Publisher('/mower_smach/active_program', String, latch=True, queue_size=1)
    pub_pm_play_melody = rospy.Publisher('/pm/play_melody', Int16, queue_size=10)
    pub_dock_cancel = rospy.Publisher('/dock_smach/stop', Bool, queue_size=1)
    save_prg_pub = rospy.Publisher("/web_plan/program_new", PlannerProgram, queue_size=1)
    pub_active_prg.publish(String(" "))
    wait_for_mbf()
    # Create SMACH state machine
    sm = smach.StateMachine(outcomes=['succeeded', 'aborted', 'preempted'])

    # Define userdata
    sm.userdata.path_plan = None
    sm.userdata.path = None
    sm.userdata.path_planner = None
    sm.userdata.path_start_pose = None
    sm.userdata.program = None
    sm.userdata.zone_cut_height = None
    sm.userdata.zone_rpm = None
    sm.userdata.zone_name = None
    sm.userdata.zone_start_pose = None
    sm.userdata.paths = None
    sm.userdata.path_cost = None
    sm.userdata.final_pose = None
    sm.userdata.prg_start_time = None
    sm.userdata.path_window_start_index = 0
    sm.userdata.path_chunk = None
    sm.userdata.path_chunk_trim_count = 0
    sm.userdata.unfinished_active = False
    sm.userdata.unfinished_zone = None
    sm.userdata.unfinished_path = None
    sm.userdata.unfinished_window = 0 
    sm.userdata.battery_capacity_checking = True
    sm.userdata.stop_in_docking = False
    # Retry counters (per failure pair) to avoid infinite recovery loops.
    sm.userdata.retry_get_path_to_start = 0
    sm.userdata.retry_get_path_to_begin = 0
    sm.userdata.retry_exe_to_begin = 0
    sm.userdata.retry_planner = 0
    pub_smach_status.publish(String("Ready"))


    # Define the periodic save callback
    def periodic_save_callback(event, sm_userdata, pub):
        # This function will be called periodically by the rospy.Timer
        # It checks if a program is running and then saves its current state.
        if sm_userdata.program is not None:
            try:
                # The last_result is updated by states like GetPathData and WindowPlannerPath.
                # This timer just ensures it's published periodically.
                pub.publish(sm_userdata.program)
            except Exception as e:
                rospy.logwarn(f"Periodic save failed: {e}")

    with sm:

        # Reinit userdata for new program
        def reinit_userdata(userdata):
            userdata.path_window_start_index = 0
            userdata.path_chunk = None
            userdata.path_chunk_trim_count = 0
            userdata.unfinished_active = False
            userdata.battery_capacity_checking = True

        # Program callback for state MONITOR_PROGRAM_ACTIVE
        def callback_program(userdata, msg):
            
            reinit_userdata(userdata)

            userdata.program = msg
            
            userdata.program.last_result = 'failed: on_init'
            rospy.loginfo('[{}]Get new program to run - state MONITOR_PROGRAM_ACTIVE'.format(rospy.get_caller_id()))
            pub_active_program = rospy.Publisher('/mower_smach/active_program', String, latch=True, queue_size=1)
            pub_active_program.publish(String(msg.name))
            pub_log_info.publish(String("Executing program: {}".format(msg.name)))
            pub_pm_play_melody.publish(Int16(2))  # 5:short_beep, 1:beep, 2:double beep,
            pub_smach_status.publish(String("Initiating"))
            rospy.sleep(1.0)
            userdata.prg_start_time = rospy.Time.now()
            if sm.preempt_requested():
                sm.service_preempt()
                return 'preempted'
            return False
        
        # Program callback for state MONITOR_PROGRAM_UNFINISHED
        def callback_program_unfinished(userdata, msg):
            
            reinit_userdata(userdata)
            userdata.program = msg

            # userdata.program.last_result = f'failed: on_path-{userdata.zone_name}-{userdata.index_path}'
            # userdata.program.last_result = 'failed: on_path-ZonefrontNewDiagonal-23-0'
            print("Program unfinished: {}".format(userdata.program.last_result))
            last_result = userdata.program.last_result.split(': ')
            print("Last result: {}".format(last_result[0]))
            if last_result[0] == 'failed':
                # Parse "on_path-<zone_name>-<path_idx>-<window>". Use rsplit so a
                # zone_name containing dashes ("front-yard-east") still works.
                failure_payload = last_result[1] if len(last_result) > 1 else ''
                tag, _, rest = failure_payload.partition('-')
                if tag == 'on_path' and rest:
                    parts = rest.rsplit('-', 2)
                    if len(parts) == 3:
                        zone_name, path_idx_str, window_str = parts
                    elif len(parts) == 2:
                        zone_name, path_idx_str = parts
                        window_str = '0'
                    else:
                        zone_name = parts[0]
                        path_idx_str = '0'
                        window_str = '0'
                    print("Failure reason: zone={} path={} window={}".format(
                        zone_name, path_idx_str, window_str))
                    userdata.unfinished_zone = zone_name
                    userdata.unfinished_path = path_idx_str
                    try:
                        userdata.unfinished_window = int(window_str)
                    except (TypeError, ValueError):
                        userdata.unfinished_window = 0
                    pub_log_info.publish(String(f"Program unfinished: {userdata.program.last_result}"))
                    userdata.unfinished_active = True

            print("Unfinished active: {}".format(userdata.unfinished_active))
            userdata.program.last_result = 'failed: on_init'
            rospy.loginfo('[{}]Get new program to run - state MONITOR_PROGRAM_UNFINISHED'.format(rospy.get_caller_id()))
            pub_active_program = rospy.Publisher('/mower_smach/active_program', String, latch=True, queue_size=1)
            pub_active_program.publish(String(msg.name))
            pub_log_info.publish(String("Executing unfinished program: {}".format(msg.name)))
            pub_pm_play_melody.publish(Int16(2))  # 5:short_beep, 1:beep, 2:double beep,
            pub_smach_status.publish(String("Initiating unfinished"))
            rospy.sleep(1.0)
            userdata.prg_start_time = rospy.Time.now()
            if sm.preempt_requested():
                sm.service_preempt()
                return 'preempted'
            return False

        def concurrence_outcome_cb(outcome_map):
            if outcome_map.get('MONITOR_PROGRAM_ACTIVE') == 'invalid' or outcome_map.get('MONITOR_PROGRAM_UNFINISHED') == 'invalid':
                return 'program_received'
            return 'preempted'

        # To monitor two topics, we use a Concurrence container.
        # It will run two MonitorState children in parallel and terminate when one of them does.
        wait_for_program_cc = smach.Concurrence(
            outcomes=['program_received', 'preempted'],
            default_outcome='preempted',
            child_termination_cb=lambda so: True,  # Terminate all children if one terminates
            output_keys=['program', 'prg_start_time', 'unfinished_active', 
                         'unfinished_zone', 'unfinished_path', 'path_window_start_index', 
                         'path_chunk', 'unfinished_window', 'battery_capacity_checking'],
            input_keys=['program', 'unfinished_active', 'unfinished_zone', 'unfinished_path', 
                        'path_window_start_index', 'path_chunk', 'prg_start_time', 
                        'unfinished_window', 'battery_capacity_checking'],
            outcome_cb=concurrence_outcome_cb
        )

        with wait_for_program_cc:
            smach.Concurrence.add('MONITOR_PROGRAM_ACTIVE',
                                  smach_ros.MonitorState('/web_plan/program_active',
                                                         PlannerProgram,
                                                         callback_program,
                                                         output_keys=['program', 'prg_start_time', 'unfinished_active', 'unfinished_zone', 
                                                                      'unfinished_path', 'path_window_start_index', 'path_chunk', 
                                                                      'battery_capacity_checking'],
                                                         input_keys=['program', 'unfinished_active', 'unfinished_zone', 'unfinished_active',
                                                                     'unfinished_path', 'path_window_start_index', 'path_chunk', 
                                                                     'prg_start_time', 'battery_capacity_checking']))

            smach.Concurrence.add('MONITOR_PROGRAM_UNFINISHED',
                                  smach_ros.MonitorState('/web_plan/program_active_unfinished',
                                                         PlannerProgram,
                                                         callback_program_unfinished,
                                                         output_keys=['program', 'prg_start_time', 'unfinished_active', 'unfinished_zone', 
                                                                      'unfinished_path', 'path_window_start_index', 'path_chunk', 
                                                                      'unfinished_window', 'battery_capacity_checking'],
                                                         input_keys=['program', 'unfinished_active', 'unfinished_zone', 'unfinished_path', 
                                                                     'path_window_start_index', 'path_chunk', 'prg_start_time', 
                                                                     'unfinished_window', 'battery_capacity_checking']))

        # Add the Concurrence container to the main state machine
        smach.StateMachine.add('WAIT_FOR_PROGRAM', wait_for_program_cc,
            transitions={
                'program_received': 'CHECK_IF_DOCKED',
                'preempted': 'PREEMPTED_STOP'
            }
        )

        ########################################  UNDOCK  ########################################
        # Add state UNDOCK and check if mower is docked. If yes, then send undocking message and go 
        # to state WAIT_TO_UNDOCKED. If not, then go to state LOAD_MAP.
        
        # A custom state to check dock status with multiple outcomes
        class CheckIfDockedState(smach.State):
            MAX_WAITS = 5  # ~25s of timeouts before giving up

            def __init__(self):
                smach.State.__init__(self, outcomes=['proceed_to_undock', 'skip_undocking', 'wait', 'preempted'])
                self.pub_log_info = rospy.Publisher('/nextion/log_info', String, queue_size=10, latch=True)
                self._wait_count = 0

            def execute(self, userdata):
                if self.preempt_requested():
                    self.service_preempt()
                    return 'preempted'

                try:
                    msg = rospy.wait_for_message('/dock_smach/dock_status', Int8, timeout=5.0)
                    self._wait_count = 0

                    if msg.data == 3:  # Undocked
                        self.pub_log_info.publish(String("Mower is already undocked."))
                        return 'skip_undocking'
                    elif msg.data == 0:  # Docked
                        self.pub_log_info.publish(String("Mower is docked, starting undock."))
                        return 'proceed_to_undock'
                    else:
                        self.pub_log_info.publish(String("Waiting for dock status, current: {}".format(msg.data)))
                        return 'wait'

                except rospy.ROSException:
                    self._wait_count += 1
                    rospy.logwarn("Timeout waiting for /dock_smach/dock_status (%d/%d).",
                                  self._wait_count, self.MAX_WAITS)
                    if self._wait_count >= self.MAX_WAITS:
                        self.pub_log_info.publish(String(
                            "No dock_status after {} tries, assuming undocked.".format(self.MAX_WAITS)))
                        self._wait_count = 0
                        return 'skip_undocking'
                    return 'wait'

        smach.StateMachine.add('CHECK_IF_DOCKED', CheckIfDockedState(),
                               transitions={'proceed_to_undock': 'GET_UNDOCK_PROGRAM',
                                            'skip_undocking': 'LOAD_MAP',
                                            'wait': 'CHECK_IF_DOCKED',
                                            'preempted': 'PREEMPTED_STOP'})

        # Callback to get the undock program (legacy, replaced by WaitForTopic+_on_undock_program below).

        # Capture undock program (timeout-bounded).
        def _on_undock_program(userdata, msg):
            userdata.undock_program = msg
            pub_log_info.publish(String("Received undock program."))
            pub_smach_status.publish(String("Undocking"))

        smach.StateMachine.add('GET_UNDOCK_PROGRAM',
                               WaitForTopic('/dock_manager/undock_program',
                                            DockProgram,
                                            predicate=lambda m: True,
                                            timeout=30.0,
                                            output_keys=['undock_program'],
                                            on_match=_on_undock_program),
                               transitions={'received': 'SEND_UNDOCK_PROGRAM',
                                            'timeout': 'LOAD_MAP',
                                            'preempted': 'PREEMPTED_STOP'})

        # State to send the undock program
        @smach.cb_interface(input_keys=['undock_program'], outcomes=['succeeded'])
        def send_undock_program_cb(userdata):
            pub_undock = rospy.Publisher('/dock_smach/start_docking', DockProgram, queue_size=1, latch=True)
            pub_undock.publish(userdata.undock_program)
            pub_log_info.publish(String("Sent undock program."))
            rospy.sleep(1.0)  # Give it a moment to publish
            return 'succeeded'

        smach.StateMachine.add('SEND_UNDOCK_PROGRAM', CBState(send_undock_program_cb),
                               transitions={'succeeded': 'WAIT_FOR_UNDOCKED'})

        # Wait for undocked status with timeout (accept both success=3 and failure=4 to continue).
        def _undocked_predicate(m):
            if m.data == 3:
                pub_log_info.publish(String("Mower successfully undocked."))
                return True
            if m.data == 4:
                pub_log_info.publish(String("Undocking failed; continuing to LOAD_MAP."))
                return True
            return False

        smach.StateMachine.add('WAIT_FOR_UNDOCKED',
                               WaitForTopic('/dock_smach/dock_status', Int8,
                                            predicate=_undocked_predicate, timeout=180.0),
                               transitions={'received': 'LOAD_MAP',
                                            'timeout': 'LOAD_MAP',
                                            'preempted': 'PREEMPTED_STOP'})

        ########################################  LOAD MAP  ########################################
        # Load desired map running by program
        # Add state LOAD_MAP
        @smach.cb_interface(input_keys=['program'], output_keys=[], outcomes=['success_indoor', 'success_outdoor', 'failure', 'preempted'])
        def set_map_cb(userdata):
            rospy.loginfo('[{}]Setting the map - state LOAD_MAP'.format(rospy.get_caller_id()))
            indoor = False
            if userdata.program.map_name.split('***env*')[1] == 'INDOOR':
                pub = rospy.Publisher('/navi_manager/load_map_rtabmap', String, latch=True, queue_size=1)
                indoor = True
            else:
                pub = rospy.Publisher('/navi_manager/load_map', String, latch=True, queue_size=1)
            msg = String()
            msg.data = userdata.program.map_name
            rospy.sleep(1.0)  # Wait for publisher-subscriber TCP connection to establish before publishing
            pub_status = pub.publish(msg)
            rospy.loginfo(f'[{{}}]LOAD_MAP: published map={userdata.program.map_name}'.format(rospy.get_caller_id()))
            pub_log_info.publish(String("Loading the map"))
            pub_smach_status.publish(String("Loading map"))
            rospy.sleep(4.0)

            if sm.preempt_requested():
                sm.service_preempt()
                return 'preempted'

            if pub_status is None:
                if indoor:
                    return 'success_indoor'
                else:
                    return 'success_outdoor'
            else:
                return 'failure'

        smach.StateMachine.add('LOAD_MAP', CBState(set_map_cb),
                               {'success_indoor': 'WAIT_FOR_RTABMAP',
                                'success_outdoor': 'WAIT_FOR_GPS_FIX',
                                'failure': 'WAIT_FOR_PROGRAM',
                                'preempted': 'PREEMPTED_STOP'})

        ########################################  RTABMAP  ########################################
        # Bounded wait for rtabmap proximity detection (indoor SLAM ready signal).
        def _rtabmap_predicate(msg):
            if msg.proximityDetectionId > 0:
                pub_log_info.publish(String("Rtabmap is ready"))
                pub_pm_play_melody.publish(Int16(1))
                pub_smach_status.publish(String("Rtabmap ready"))
                rospy.sleep(0.5)
                return True
            return False

        smach.StateMachine.add('WAIT_FOR_RTABMAP',
                               WaitForTopic('/rtabmap/info', Info,
                                            predicate=_rtabmap_predicate, timeout=180.0),
                               transitions={
                                   'received': 'WAIT_FOR_PLANNER',
                                   'timeout': 'PREEMPTED_STOP',
                                   'preempted': 'PREEMPTED_STOP'})

        ########################################  GPS_FIX  ########################################
        def _gps_predicate(msg):
            if msg.gnss == 'RTK':
                pub_log_info.publish(String("RTK fix aquired"))
                pub_smach_status.publish(String("RTK fix aquired"))
                rospy.sleep(0.5)
                return True
            return False

        # GPS RTK fix can take a long time (cold start); allow up to 10 minutes.
        smach.StateMachine.add('WAIT_FOR_GPS_FIX',
                               WaitForTopic('/device_state_pub/icon_status',
                                            Device_icon_status,
                                            predicate=_gps_predicate, timeout=600.0),
                               transitions={
                                   'received': 'WAIT_FOR_PLANNER',
                                   'timeout': 'PREEMPTED_STOP',
                                   'preempted': 'PREEMPTED_STOP'})

        ########################################  PLANNER  ########################################
        # Planner_loaded predicate needs userdata.program.map_name; use a dedicated state.
        class WaitForPlannerLoaded(smach.State):
            def __init__(self, timeout=120.0):
                smach.State.__init__(self,
                                     outcomes=['received', 'timeout', 'preempted'],
                                     input_keys=['program'], output_keys=['program'])
                self.timeout = float(timeout)

            def execute(self, userdata):
                userdata.program.last_result = 'failed: on_planner'
                deadline = rospy.Time.now() + rospy.Duration(self.timeout)
                target = userdata.program.map_name
                show_map_planner_pub = rospy.Publisher("/web_plan/show_map_layer", String,
                                                       latch=True, queue_size=1)
                while not rospy.is_shutdown() and rospy.Time.now() < deadline:
                    if self.preempt_requested():
                        self.service_preempt()
                        return 'preempted'
                    try:
                        msg = rospy.wait_for_message('/web_plan/planner_loaded', String, timeout=1.0)
                    except rospy.ROSException:
                        continue
                    if msg.data == target:
                        show_map_planner_pub.publish(String("SMACH|MAP|FULL"))
                        pub_log_info.publish(String("Map is ready"))
                        pub_smach_status.publish(String("Map ready"))
                        pub_pm_play_melody.publish(Int16(1))
                        rospy.sleep(2.0)
                        return 'received'
                rospy.logwarn('WAIT_FOR_PLANNER timeout (%.1fs) waiting for map=%s',
                              self.timeout, target)
                return 'timeout'

        smach.StateMachine.add('WAIT_FOR_PLANNER', WaitForPlannerLoaded(timeout=120.0),
                               transitions={
                                   'received': 'POWER_ON_MOWER',
                                   'timeout': 'PREEMPTED_STOP',
                                   'preempted': 'PREEMPTED_STOP'})



        ########################################  MOWER  ########################################
        # Add state POWER_ON_MOWER
        @smach.cb_interface(input_keys=['program'], output_keys=['program'], outcomes=['success', 'failure'])
        def turn_on_mower_cb(userdata):
            userdata.program.last_result = 'failed: on_mower'
            rospy.loginfo('[{}]Turning on mower - state POWER_ON_MOWER'.format(rospy.get_caller_id()))
            pub_mower_set_power = rospy.Publisher('/mower/set_power', Bool, latch=True, queue_size=1)
            msg = Bool()
            msg.data = True
            pub_status = pub_mower_set_power.publish(msg)
            pub_log_info.publish(String("Turn on mower"))
            pub_smach_status.publish(String("Turn on mower"))
            pub_pm_play_melody.publish(Int16(1))  # 5:short_beep, 1:beep, 2:double beep,
            rospy.sleep(2.5)
            if pub_status is None:
                return 'success'

        smach.StateMachine.add('POWER_ON_MOWER', CBState(turn_on_mower_cb),
                               {'success': 'WAIT_FOR_MOWER_ON',
                                'failure': 'POWER_ON_MOWER'})

        # Bounded wait for /mower/status==READY (or FW error).
        def _on_mower_ready(_msg):
            pub_log_info.publish(String("Mower is ready"))
            pub_smach_status.publish(String("Mower ready"))
            pub_pm_play_melody.publish(Int16(1))
            return True

        smach.StateMachine.add('WAIT_FOR_MOWER_ON',
                               WaitForMowerStatus('READY', timeout=30.0,
                                                  extra_check=_on_mower_ready),
                               transitions={
                                   'reached': 'ZONE_IT',
                                   'error': 'PREEMPTED_STOP',
                                   'timeout': 'PREEMPTED_STOP',
                                   'preempted': 'PREEMPTED_STOP'})

        ########################################################################################
        ########################################  ZONE  ########################################
        ########################################################################################

        # Iterator for zones
        zone_it = Iterator(outcomes=['succeeded', 'preempted', 'aborted'],
                           input_keys=['program', 'zone_cut_height', 'zone_rpm', 'zone_name', 'zone_start_pose',
                                       'path_plan', 'paths', 'path_window_start_index',
                                       'retry_get_path_to_start', 'retry_get_path_to_begin',
                                       'retry_exe_to_begin', 'retry_planner'],
                           it=lambda: range(0, len(sm.userdata.program.zone_list)),
                           output_keys=['zone_cut_height', 'zone_rpm', 'zone_name', 'zone_start_pose', 'path_plan',
                                        'paths', 'path_window_start_index',
                                        'retry_get_path_to_start', 'retry_get_path_to_begin',
                                        'retry_exe_to_begin', 'retry_planner'],
                           it_label='index',
                           exhausted_outcome='succeeded')
        zone_it.userdata = sm.userdata
        with zone_it:
            # Create smach state machine for processing zone
            process_zone_sm = smach.StateMachine(outcomes=['succeeded', 'preempted', 'aborted', 'continue'],
                                                 input_keys=['program', 'zone_cut_height', 'zone_rpm', 'index',
                                                             'zone_name', 'zone_start_pose', 'path_plan', 'paths', 'path_window_start_index',
                                                             'retry_get_path_to_start', 'retry_get_path_to_begin',
                                                             'retry_exe_to_begin', 'retry_planner'],
                                                 output_keys=['zone_cut_height', 'zone_rpm', 'zone_name', 'zone_start_pose', 'path_plan', 'paths', 'path_window_start_index',
                                                              'retry_get_path_to_start', 'retry_get_path_to_begin',
                                                              'retry_exe_to_begin', 'retry_planner'])
            process_zone_sm.userdata = zone_it.userdata

            with process_zone_sm:
                # Add state GET_ZONE_DATA
                smach.StateMachine.add('GET_ZONE_DATA', GetZoneData(),
                                       transitions={'available': 'GET_PATH_TO_START',
                                                    'failed': 'aborted',
                                                    'preempted': 'preempted',
                                                    'skip_zone': 'continue'})

                # Add state GET_PATH_TO_START - Get path to start point of the zone
                def get_path_result_cb(userdata, status, result):
                    if process_path_sm.preempt_requested():
                        process_path_sm.service_preempt()
                        return 'preempted'
                    cls = classify_mbf_result('GET_PATH_TO_START', status, result, log_pub=pub_log_info)
                    if cls == 'succeeded':
                        pub_log_info.publish(String("Go to zone begin"))
                        pub_smach_status.publish(String("Go to zone begin"))
                        pub_pm_play_melody.publish(Int16(2))  # 5:short_beep, 1:beep, 2:double beep,
                    return cls

                def get_path_goal_cb(userdata, goal):
                    # print("get path goal: {}".format(goal))
                    wait_for_mbf()

                smach.StateMachine.add('GET_PATH_TO_START', smach_ros.SimpleActionState(
                    '/move_base_flex/get_path', GetPathAction, goal_slots=['target_pose'],
                    result_slots=['path'], goal_cb=get_path_goal_cb, result_cb=get_path_result_cb
                ),
                                       transitions={
                                           'succeeded': 'EXE_PATH_TO_START',
                                           'aborted': 'RG_GET_PATH_TO_START',
                                           'preempted': 'preempted'
                                       },
                                       remapping={
                                           'target_pose': 'zone_start_pose',
                                           'path': 'path_plan'
                                       }
                                       )

                # Retry gate for GET_PATH_TO_START / RECOVERY -> GET_PATH_TO_START loop.
                smach.StateMachine.add('RG_GET_PATH_TO_START',
                                       RetryLimitedAction('retry_get_path_to_start', max_retries=3),
                                       transitions={'retry': 'GET_PATH_TO_START',
                                                    'give_up': 'aborted',
                                                    'preempted': 'preempted'})

                # Add state EXE_PATH_TO_START - Execute path to start point
                def get_exe_result_cb(userdata, status, result):
                    if process_path_sm.preempt_requested():
                        process_path_sm.service_preempt()
                        return 'preempted'
                    return classify_mbf_result('EXE_PATH_TO_START', status, result, log_pub=pub_log_info)

                smach.StateMachine.add('EXE_PATH_TO_START', smach_ros.SimpleActionState(
                    '/move_base_flex/exe_path', ExePathAction, goal_slots=['path'], result_cb=get_exe_result_cb,
                    input_keys=['paths']
                ),
                                       transitions={
                                           'succeeded': 'VERIFY_AT_ZONE_START',
                                           'aborted': 'RECOVERY',
                                           'preempted': 'preempted'
                                       }, remapping={'path': 'path_plan'}
                                       )

                # Defensive arrival check: even when MBF reports SUCCESS we confirm
                # via TF that the robot is actually within 0.5 m of the target pose
                # before we start cutting. If not, route through RECOVERY -> retry
                # gate just like a real abort.
                smach.StateMachine.add('VERIFY_AT_ZONE_START',
                                       VerifyAtPose('zone_start_pose', tolerance=0.5,
                                                    label='VERIFY_AT_ZONE_START'),
                                       transitions={
                                           'arrived': 'SET_CUT_HEIGHT',
                                           'not_arrived': 'RECOVERY',
                                           # If TF is unavailable, be permissive -- we just lost
                                           # localisation, but EXE_PATH said it succeeded.
                                           'tf_unavailable': 'SET_CUT_HEIGHT',
                                           'preempted': 'preempted'
                                       })

                # Goal callback for state RECOVERY
                def recovery_path_goal_to_start_cb(userdata, goal):
                    pub_log_info = rospy.Publisher('/nextion/log_info', String, queue_size=10, latch=True)
                    pub_log_info.publish(String("Recovery"))

                    goal.behavior = 'clear_costmap'

                # Recovery -> retry gate (max 3 attempts before aborting the zone).
                smach.StateMachine.add(
                    'RECOVERY',
                    smach_ros.SimpleActionState(
                        'move_base_flex/recovery',
                        RecoveryAction,
                        goal_cb=recovery_path_goal_to_start_cb,
                        input_keys=["error", "clear_costmap_flag"],
                        output_keys=["error_status", 'clear_costmap_flag']
                    ),
                    transitions={
                        'succeeded': 'RG_GET_PATH_TO_START',
                        'aborted': 'RG_GET_PATH_TO_START',
                        'preempted': 'preempted'
                    }
                )


                # Add state SET_CUT_HEIGHT
                @smach.cb_interface(input_keys=['zone_cut_height'], output_keys=[], outcomes=['success', 'failure'])
                def set_height_cb(userdata):
                    rospy.loginfo(
                        '[{}]Setting cut height on mower - state SET_CUT_HEIGHT'.format(rospy.get_caller_id()))
                    pub_mower_set_cut_height = rospy.Publisher('/mower/set_cut_height', Int16, latch=True, queue_size=1)
                    msg = Int16()
                    msg.data = userdata.zone_cut_height
                    pub_status = pub_mower_set_cut_height.publish(msg)
                    pub_log_info.publish(String("Setting mower height"))
                    pub_smach_status.publish(String("Setting height"))
                    pub_pm_play_melody.publish(Int16(1))  # 5:short_beep, 1:beep, 2:double beep,
                    rospy.sleep(1.5)
                    if pub_status is None:
                        return 'success'

                smach.StateMachine.add('SET_CUT_HEIGHT', CBState(set_height_cb),
                                       {'success': 'WAIT_FOR_SET_CUT_HEIGHT', 'failure': 'SET_CUT_HEIGHT'})

                # Bounded wait for blade to reach commanded height (FW transitions through
                # CHANGE_HEIGHT and back to READY). Height move can be slow → 120 s budget.
                smach.StateMachine.add('WAIT_FOR_SET_CUT_HEIGHT',
                                       WaitForMowerStatus('READY', timeout=120.0),
                                       transitions={
                                           'reached': 'SET_RPM',
                                           'error': 'preempted',
                                           'timeout': 'preempted',
                                           'preempted': 'preempted'})

                # Add state SET_RPM
                @smach.cb_interface(input_keys=['zone_rpm'], output_keys=[], outcomes=['success', 'failure'])
                def set_rpm_cb(userdata):
                    rospy.loginfo(
                        '[{}]Setting motor rpm on mower - state SET_RPM'.format(rospy.get_caller_id()))
                    pub_mower_set_motor_rpm = rospy.Publisher('/mower/set_motor_rpm', Int16, latch=True, queue_size=1)
                    msg = Int16()
                    msg.data = userdata.zone_rpm
                    pub_status = pub_mower_set_motor_rpm.publish(msg)
                    pub_smach_status.publish(String("Set rpm"))
                    if pub_status is None:
                        return 'success'

                smach.StateMachine.add('SET_RPM', CBState(set_rpm_cb),
                                       {'success': 'SET_MOTOR_ON', 'failure': 'SET_RPM'})

                # Add state SET_MOTOR_ON
                @smach.cb_interface(input_keys=[], output_keys=[], outcomes=['success', 'failure'])
                def set_motor_on_cb(userdata):
                    rospy.loginfo(
                        '[{}]Setting mower motor on - state SET_MOTOR_ON'.format(rospy.get_caller_id()))
                    pub_mower_set_motor_on = rospy.Publisher('/mower/set_motor_on', Bool, latch=True, queue_size=1)
                    msg = Bool()
                    msg.data = True
                    pub_status = pub_mower_set_motor_on.publish(msg)

                    if pub_status is None:
                        return 'success'

                smach.StateMachine.add('SET_MOTOR_ON', CBState(set_motor_on_cb),
                                       {'success': 'WAIT_FOR_SET_RPM', 'failure': 'SET_MOTOR_ON'})

                # Bounded wait for cutting motor to reach setpoint RPM (±100). Detects FW
                # error states (ERR/BLOCKED/TEMP) and gives up after 30 s.
                class WaitForRpmReached(smach.State):
                    def __init__(self, timeout=30.0):
                        smach.State.__init__(self,
                                             outcomes=['reached', 'error', 'timeout', 'preempted'],
                                             input_keys=['zone_rpm'], output_keys=[])
                        self.timeout = float(timeout)

                    def execute(self, userdata):
                        deadline = rospy.Time.now() + rospy.Duration(self.timeout)
                        target = int(userdata.zone_rpm)
                        while not rospy.is_shutdown() and rospy.Time.now() < deadline:
                            if self.preempt_requested():
                                self.service_preempt()
                                return 'preempted'
                            try:
                                msg = rospy.wait_for_message('/mower/status', Mower, timeout=1.0)
                            except rospy.ROSException:
                                continue
                            if msg.status in MOWER_ERROR_STATES:
                                rospy.logwarn('[WAIT_FOR_SET_RPM] FW error: %s', msg.status)
                                return 'error'
                            if target - 100 < msg.moto_rpm < target + 100:
                                pub_log_info.publish(String("Mowing started..."))
                                pub_smach_status.publish(String("Mowing started"))
                                return 'reached'
                        rospy.logwarn('[WAIT_FOR_SET_RPM] timeout (%.1fs) target=%d', self.timeout, target)
                        return 'timeout'

                smach.StateMachine.add('WAIT_FOR_SET_RPM', WaitForRpmReached(timeout=30.0),
                                       transitions={
                                           'reached': 'PATH_IT',
                                           'error': 'preempted',
                                           'timeout': 'preempted',
                                           'preempted': 'preempted'})

                ########################################################################################
                #####################################  PATHS  ##########################################
                ########################################################################################

                # Iterate trough paths
                # Provide mowing of paths in zone
                # Iterator for paths
                path_it = Iterator(outcomes=['succeeded', 'preempted', 'aborted'],
                                   input_keys=['program', 'path_plan', 'zone_cut_height', 'zone_rpm',
                                               'zone_name', 'zone_start_pose', 'paths', 'path_window_start_index',
                                               'retry_get_path_to_begin', 'retry_exe_to_begin', 'retry_planner'],
                                   it=lambda: range(0, len(process_zone_sm.userdata.paths)),
                                   output_keys=['path_plan', 'zone_cut_height', 'zone_rpm', 'zone_name',
                                                'zone_start_pose', 'index_path', 'path_window_start_index',
                                                'retry_get_path_to_begin', 'retry_exe_to_begin', 'retry_planner'],
                                   it_label='index_path',
                                   exhausted_outcome='succeeded')
                path_it.userdata = process_zone_sm.userdata

                with path_it:
                    # Create smach state machine for processing path
                    process_path_sm = smach.StateMachine(
                        outcomes=['succeeded_path', 'preempted', 'aborted_path', 'continue_path'],
                        input_keys=['program', 'zone_cut_height', 'zone_rpm', 'index', 
                                    'zone_name', 'zone_start_pose', 'path_plan', 'index_path', 'paths', 'path_window_start_index', 'path',
                                    'retry_get_path_to_begin', 'retry_exe_to_begin', 'retry_planner'],
                        output_keys=['zone_cut_height', 'zone_rpm', 'zone_name', 'program', 
                                     'zone_start_pose', 'path_plan', 'path_window_start_index'])
                    process_path_sm.userdata = path_it.userdata

                    with process_path_sm:
                        # Add state GET_PATH_DATA
                        smach.StateMachine.add('GET_PATH_DATA', GetPathData(save_prg_pub),
                                               transitions={'available': 'GET_PATH_TO_BEGIN_OF_PATH',
                                                            'preempted': 'preempted',
                                                            'skip_path': 'continue_path'})

                        # Add state GET_PATH_TO_BEGIN_OF_PATH - Get path to start point of the zone
                        def get_path_to_path_result_cb(userdata, status, result):
                            pub_log_info.publish(String("{}: go to path {}/{}".format(userdata.zone_name, userdata.index_path+1, len(userdata.paths))))
                            pub_smach_status.publish(String("{}: go to path {}/{}".format(userdata.zone_name, userdata.index_path+1, len(userdata.paths))))

                            if process_path_sm.preempt_requested():
                                process_path_sm.service_preempt()
                                return 'preempted'

                            cls = classify_mbf_result('GET_PATH_TO_BEGIN_OF_PATH', status, result,
                                                      log_pub=pub_log_info)
                            if cls == 'succeeded':
                                userdata.path_cost = result.cost
                            return cls

                        smach.StateMachine.add('GET_PATH_TO_BEGIN_OF_PATH', smach_ros.SimpleActionState(
                                            '/move_base_flex/get_path', GetPathAction, goal_slots=['target_pose'],
                                            result_slots=['path'], input_keys=['path_start_pose', 'path', 'path_planner', 'path_cost',
                                                                               'zone_name', 'index_path', 'paths', 'program'],
                                            output_keys=['path_cost', 'program' ], result_cb=get_path_to_path_result_cb
                                        ),
                                        transitions={
                                           'succeeded': 'CHECK_DISTANCE',
                                           'aborted': 'RG_GET_PATH_TO_BEGIN',
                                           'preempted': 'preempted'
                                        },
                                        remapping={
                                           'target_pose': 'path_start_pose',
                                           'path': 'path_plan'
                                        })

                        # Retry gate: 3 attempts then skip this path entirely.
                        smach.StateMachine.add('RG_GET_PATH_TO_BEGIN',
                                               RetryLimitedAction('retry_get_path_to_begin', max_retries=3),
                                               transitions={'retry': 'GET_PATH_TO_BEGIN_OF_PATH',
                                                            'give_up': 'continue_path',
                                                            'preempted': 'preempted'})

                        # Add state CHECK_DISTANCE - check if is on place or not
                        smach.StateMachine.add('CHECK_DISTANCE', CheckDistance(),
                                               transitions={'on_place': 'CHECK_PLANNER_PATH',
                                                            'exe_path': 'EXE_PATH_TO_BEGIN_OF_PATH',
                                                            'preempted': 'preempted'})

                        # Add state EXE_PATH_TO_BEGIN_OF_PATH - Execute path to start point
                        def get_exe_to_path_result_cb(userdata, status, result):
                            pub_log_info.publish(
                                String("{}: go to path {}/{}".format(userdata.zone_name, userdata.index_path+1, len(userdata.paths))))
                            pub_smach_status.publish(
                                String("{}: go to path {}/{}".format(userdata.zone_name, userdata.index_path+1, len(userdata.paths))))
                            if process_path_sm.preempt_requested():
                                process_path_sm.service_preempt()
                                return 'preempted'
                            return classify_mbf_result('EXE_PATH_TO_BEGIN_OF_PATH', status, result,
                                                       log_pub=pub_log_info)

                        smach.StateMachine.add('EXE_PATH_TO_BEGIN_OF_PATH', smach_ros.SimpleActionState(
                            '/move_base_flex/exe_path', ExePathAction, goal_slots=['path'],
                            result_cb=get_exe_to_path_result_cb,
                            input_keys=['paths', 'zone_name', 'index_path', 'zone_name', 'index_path']
                        ),
                                               transitions={
                                                   'succeeded': 'VERIFY_AT_PATH_START',
                                                   'aborted': 'RECOVERY_BEGIN',
                                                   'preempted': 'preempted'
                                               }, remapping={'path': 'path_plan'}
                                               )

                        # Defensive arrival check before we treat the path as ready to mow.
                        smach.StateMachine.add('VERIFY_AT_PATH_START',
                                               VerifyAtPose('path_start_pose', tolerance=0.5,
                                                            label='VERIFY_AT_PATH_START'),
                                               transitions={
                                                   'arrived': 'CHECK_PLANNER_PATH',
                                                   'not_arrived': 'RECOVERY_BEGIN',
                                                   'tf_unavailable': 'CHECK_PLANNER_PATH',
                                                   'preempted': 'preempted'
                                               })

                        # Goal callback for state RECOVERY
                        def recovery_path_goal_to_begin_cb(userdata, goal):
                            pub_log_info = rospy.Publisher('/nextion/log_info', String, queue_size=10, latch=True)
                            pub_log_info.publish(String("Recovery"))

                            goal.behavior = 'clear_costmap'

                        # Recovery + retry gate (max 3 attempts before skipping the path).
                        smach.StateMachine.add(
                            'RECOVERY_BEGIN',
                            smach_ros.SimpleActionState(
                                'move_base_flex/recovery',
                                RecoveryAction,
                                goal_cb=recovery_path_goal_to_begin_cb,
                                input_keys=["error", "clear_costmap_flag"],
                                output_keys=["error_status", 'clear_costmap_flag']
                            ),
                            transitions={
                                'succeeded': 'RG_EXE_TO_BEGIN',
                                'aborted': 'RG_EXE_TO_BEGIN',
                                'preempted': 'preempted'
                            }
                        )

                        smach.StateMachine.add('RG_EXE_TO_BEGIN',
                                               RetryLimitedAction('retry_exe_to_begin', max_retries=3),
                                               transitions={'retry': 'EXE_PATH_TO_BEGIN_OF_PATH',
                                                            'give_up': 'continue_path',
                                                            'preempted': 'preempted'})


                        # Add state CHECK_PLANNER_PATH - service call to check path
                        @smach.cb_interface(input_keys=['path', 'zone_name', 'index_path', 'paths'])
                        def check_path_request_cb(userdata, request):
                            pub_log_info.publish(
                                String("{}: exe path {}/{}".format(userdata.zone_name, userdata.index_path+1, len(userdata.paths))))
                            pub_smach_status.publish(
                                String("{}: exe path {}/{}".format(userdata.zone_name, userdata.index_path+1, len(userdata.paths))))
                            srvs_request = CheckPathRequest()
                            srvs_request.path = userdata.path
                            srvs_request.safety_dist = 0.1
                            srvs_request.lethal_cost_mult = 0
                            srvs_request.inscrib_cost_mult = 0
                            srvs_request.unknown_cost_mult = 0
                            srvs_request.costmap = CheckPathRequest.GLOBAL_COSTMAP
                            srvs_request.skip_poses = 0
                            srvs_request.use_padded_fp = False
                            srvs_request.path_cells_only = False

                            return srvs_request

                        def check_path_response_cb(userdata, response):
                            # print("result: {}".format(response))
                            return 'succeeded'

                        smach.StateMachine.add('CHECK_PLANNER_PATH',
                                               ServiceState('/move_base_flex/check_path_cost',
                                                            CheckPath,
                                                            request_cb=check_path_request_cb,
                                                            response_cb=check_path_response_cb,
                                                            input_keys=['path', 'zone_name', 'index_path', 'paths']),
                                               transitions={'succeeded': 'WINDOW_PLANNER_PATH',
                                                            'aborted': 'TRIM_AND_RETRY',
                                                            'preempted': 'preempted'})

                        # Add state TRIM_AND_RETRY - trim chunk end on costmap check failure
                        smach.StateMachine.add('TRIM_AND_RETRY', TrimAndRetry(),
                                               transitions={'retry': 'CHECK_PLANNER_PATH',
                                                            'bypass_check': 'EXE_PLANNER_PATH',
                                                            'preempted': 'preempted'})

                        # Add state WINDOW_PLANNER_PATH
                        smach.StateMachine.add('WINDOW_PLANNER_PATH', WindowPlannerPath(save_prg_pub),
                                               transitions={'available': 'EXE_PLANNER_PATH',
                                                            'finished': 'continue_path',
                                                            'preempted': 'preempted'})

                        # Custom state to execute a path and get feedback
                        class ExecutePathWithFeedback(smach.State):
                            def __init__(self):
                                smach.State.__init__(self,
                                                     outcomes=['succeeded', 'aborted', 'preempted', 'replan_needed'],
                                                     input_keys=['path_chunk', 'paths', 'zone_name', 'index_path',
                                                                 'final_pose', 'path', 'path_window_start_index'])
                                self._client = actionlib.SimpleActionClient('/move_base_flex/exe_path', ExePathAction)
                                self._feedback_sub = None
                                self.last_feedback = None
                                self.step_size = 100  # Must match WindowPlannerPath
                                if not self._client.wait_for_server(rospy.Duration(5.0)):
                                    rospy.logerr("Action server '/move_base_flex/exe_path' not available")
                                    raise RuntimeError("Action server '/move_base_flex/exe_path' not available")

                            def feedback_cb(self, msg):
                                # rospy.loginfo('Distance to goal: %.2f m' % msg.feedback.dist_to_goal)
                                self.last_feedback = msg.feedback

                            def execute(self, userdata):
                                if self.preempt_requested():
                                    self.service_preempt()
                                    return 'preempted'

                                # Determine if the *next* window would be out of bounds.
                                # If so, this is the last executable chunk, and we should let it finish completely.
                                is_last_chunk = (userdata.path_window_start_index + self.step_size) >= len(
                                    userdata.path.poses)

                                self.last_feedback = None
                                self._feedback_sub = rospy.Subscriber('/move_base_flex/exe_path/feedback',
                                                                      ExePathActionFeedback, self.feedback_cb)

                                goal = ExePathGoal()
                                goal.path = userdata.path_chunk
                                self._client.send_goal(goal)

                                # Loop while the action is running
                                while self._client.get_state() in [actionlib.GoalStatus.PENDING,
                                                                   actionlib.GoalStatus.ACTIVE]:
                                    if self.preempt_requested():
                                        self._client.cancel_goal()
                                        if self._feedback_sub:
                                            self._feedback_sub.unregister()
                                        self.service_preempt()
                                        return 'preempted'

                                    # If we are close to the end of the current chunk, and it's not the final one,
                                    # return 'replan_needed' to trigger the next window planning.
                                    # Cancel the current goal so the action server stops driving toward
                                    # the (about-to-be-replaced) chunk endpoint before we send the next one.
                                    if not is_last_chunk and self.last_feedback and self.last_feedback.dist_to_goal < 0.4:
                                        rospy.loginfo("Nearing end of chunk, planning next window for smooth transition.")
                                        self._client.cancel_goal()
                                        # Brief wait so the controller actually releases /cmd_vel before
                                        # the new goal is sent; ignore timeout.
                                        self._client.wait_for_result(rospy.Duration(0.5))
                                        if self._feedback_sub:
                                            self._feedback_sub.unregister()
                                        return 'replan_needed'

                                    rospy.sleep(0.1)

                                # Action is finished (not pending or active anymore)
                                if self._feedback_sub:
                                    self._feedback_sub.unregister()
                                    self._feedback_sub = None

                                result = self._client.get_result()
                                status = self._client.get_state()

                                # rospy.loginfo("exe path status: %s", str(status))
                                # rospy.loginfo("exe path result message: %s", result.message)
                                # rospy.loginfo("exe path outcome: %d", result.outcome)
                                pub_log_info.publish(
                                    String("{}: path {}/{} done".format(userdata.zone_name, userdata.index_path + 1,
                                                                        len(userdata.paths))))
                                pub_smach_status.publish(
                                    String("{}: path {}/{} done".format(userdata.zone_name, userdata.index_path + 1,
                                                                        len(userdata.paths))))

                                if result is None:
                                    rospy.logerr("None result received from action server.")
                                    return 'aborted'
                                if result.outcome == 0:  # SUCCESS
                                    return 'succeeded'
                                else:
                                    return 'aborted'

                        smach.StateMachine.add('EXE_PLANNER_PATH', ExecutePathWithFeedback(),
                                               transitions={
                                                   'succeeded': 'WINDOW_PLANNER_PATH',
                                                   'replan_needed': 'WINDOW_PLANNER_PATH',
                                                   'aborted': 'RECOVERY_PLANNER',
                                                   'preempted': 'preempted'
                                               },
                                               remapping={'path_chunk': 'path_chunk',
                                                          'paths': 'paths',
                                                          'zone_name': 'zone_name',
                                                          'index_path': 'index_path',
                                                          'final_pose': 'final_pose',
                                                          'path': 'path',
                                                          'path_window_start_index': 'path_window_start_index'})

                        # Custom state to check distance to goal before recovery
                        class RecoveryPlannerWithDistanceCheck(smach.State):
                            def __init__(self):
                                smach.State.__init__(self,
                                                     outcomes=['continue_path', 'retry_path', 'preempted'],
                                                     input_keys=['path', 'path_chunk', 'zone_name', 'index_path', 'paths'])
                                self._recovery_client = actionlib.SimpleActionClient('move_base_flex/recovery', RecoveryAction)
                                if not self._recovery_client.wait_for_server(rospy.Duration(5.0)):
                                    rospy.logerr("Recovery action server not available")

                            def execute(self, userdata):
                                if self.preempt_requested():
                                    self.service_preempt()
                                    return 'preempted'

                                # Get current robot position via the shared TF listener.
                                try:
                                    listener = get_tf_listener()
                                    listener.waitForTransform('map', 'base_link', rospy.Time(), rospy.Duration(4.0))
                                    (trans, rot) = listener.lookupTransform('map', 'base_link', rospy.Time())
                                    current_pos = Point(x=trans[0], y=trans[1], z=trans[2])
                                    
                                    # Calculate distance to the goal (last pose in the path)
                                    goal_pos = userdata.path.poses[-1].pose.position
                                    distance_to_goal = ((current_pos.x - goal_pos.x)**2 + 
                                                       (current_pos.y - goal_pos.y)**2)**0.5
                                    
                                    rospy.loginfo("Distance to goal: %.2f m", distance_to_goal)
                                    pub_log_info.publish(String("Distance to goal: {:.2f}m".format(distance_to_goal)))
                                    
                                    # If close to goal (<=0.3m), continue to next path
                                    if distance_to_goal <= 0.3:
                                        pub_log_info.publish(String("{}: path {}/{} completed (close to goal)".format(
                                            userdata.zone_name, userdata.index_path+1, len(userdata.paths))))
                                        pub_smach_status.publish(String("{}: path {}/{} completed".format(
                                            userdata.zone_name, userdata.index_path+1, len(userdata.paths))))
                                        return 'continue_path'
                                    
                                except (tf.LookupException, tf.ConnectivityException, tf.ExtrapolationException) as e:
                                    rospy.logwarn("Failed to get robot position for distance check: %s", str(e))
                                
                                # If not close to goal, perform recovery
                                pub_log_info.publish(String("Recovery - distance to goal > 0.5m"))
                                
                                goal = RecoveryGoal()
                                goal.behavior = 'clear_costmap'
                                
                                self._recovery_client.send_goal(goal)
                                self._recovery_client.wait_for_result()
                                
                                result = self._recovery_client.get_result()
                                status = self._recovery_client.get_state()
                                
                                if status == actionlib.GoalStatus.SUCCEEDED:
                                    return 'retry_path'
                                else:
                                    return 'retry_path'  # Try again even if recovery failed

                        # Recovery + retry gate (max 3 attempts before skipping the path).
                        smach.StateMachine.add(
                            'RECOVERY_PLANNER',
                            RecoveryPlannerWithDistanceCheck(),
                            transitions={
                                'continue_path': 'continue_path',
                                'retry_path': 'RG_PLANNER',
                                'preempted': 'preempted'
                            }
                        )

                        smach.StateMachine.add('RG_PLANNER',
                                               RetryLimitedAction('retry_planner', max_retries=3),
                                               transitions={'retry': 'EXE_PLANNER_PATH',
                                                            'give_up': 'continue_path',
                                                            'preempted': 'preempted'})

                    # close processing path. Loop on continue_path (normal next-path)
                    # and on aborted_path (path bailed out via retry-exhaustion); both
                    # advance the iterator to the next path in this zone.
                    Iterator.set_contained_state('PROCESS_PATH', process_path_sm,
                                                 loop_outcomes=['continue_path', 'aborted_path'])

                # close Iterator for paths. PATH_IT 'aborted' ends the zone gracefully
                # via SET_MOTOR_OFF_AND_HOME so the mower is left in a safe state.
                smach.StateMachine.add('PATH_IT', path_it,
                                       {'succeeded': 'SET_MOTOR_OFF_AND_HOME',
                                        'aborted': 'SET_MOTOR_OFF_AND_HOME',
                                        'preempted': 'preempted'})

                # Add state SET_MOTOR_OFF_AND_HOME
                @smach.cb_interface(input_keys=['program', 'zone_name', 'index_path'], output_keys=['program'], outcomes=['success', 'failure'])
                def set_motor_off_cb(userdata):
                    rospy.loginfo(
                        '[{}]Raising blade to max and turning motor off - state SET_MOTOR_OFF_AND_HOME'.format(rospy.get_caller_id()))
                    userdata.program.last_result = f'succeeded'
                    show_map_planner_pub = rospy.Publisher("/web_plan/show_map_layer", String, latch=True, queue_size=1)
                    show_map_planner_pub.publish(String("SMACH|MAP|FULL"))
                    pub_smach_status.publish(String("Raising blade to max"))

                    # Stop motor + raise blade to max_height before any power-off so
                    # the FW does not trigger an automatic HOME cycle.
                    safe_blade_shutdown(source='SET_MOTOR_OFF_AND_HOME')
                    return 'success'

                smach.StateMachine.add('SET_MOTOR_OFF_AND_HOME', CBState(set_motor_off_cb),
                                       {'success': 'WAIT_SET_MOTOR_OFF_AND_HOME', 'failure': 'SET_MOTOR_OFF_AND_HOME'})

                # Bounded wait for /mower/status==READY after motor off + blade-up.
                # FW transitions through CHANGE_HEIGHT during blade raise; allow up to 60 s.
                smach.StateMachine.add('WAIT_SET_MOTOR_OFF_AND_HOME',
                                       WaitForMowerStatus('READY', timeout=60.0),
                                       transitions={
                                           'reached': 'continue',
                                           'error': 'continue',
                                           'timeout': 'continue',
                                           'preempted': 'preempted'})

            # close processing zone
            Iterator.set_contained_state('PROCESS_ZONE', process_zone_sm, loop_outcomes=['continue'])

        # close Iterator for zones. A failing zone ('aborted') no longer kills the
        # whole program — we still try to power off and dock cleanly.
        smach.StateMachine.add('ZONE_IT', zone_it,
                               {'succeeded': 'POWER_OFF_MOWER',
                                'aborted': 'POWER_OFF_MOWER',
                                'preempted': 'PREEMPTED_STOP'})

        # Add state PREEMPTED_STOP. Note: ``success`` is intentionally not
        # mapped \u2014 the callback only ever returns ``failure`` or ``reset``.
        @smach.cb_interface(input_keys=['stop_in_docking'], output_keys=['stop_in_docking'], outcomes=['failure', 'reset'])
        def preempted_stop_cb(userdata):
            rospy.loginfo(
                '[{}]Stopping program - state PREEMPTED_STOP (stop_in_docking={})'.format(
                    rospy.get_caller_id(), userdata.stop_in_docking))
            pub_log_info.publish(String("Stopping program"))
            pub_smach_status.publish(String("Stopping program"))
            show_map_planner_pub = rospy.Publisher("/web_plan/show_map_layer", String, latch=True, queue_size=1)
            show_map_planner_pub.publish(String("SMACH|MAP|FULL"))
            pub_pm_play_melody.publish(Int16(1))  # 5:short_beep, 1:beep, 2:double beep,
            rospy.sleep(1.5)
            sm.recall_preempt()
            zone_it.recall_preempt()
            process_zone_sm.recall_preempt()
            path_it.recall_preempt()
            process_path_sm.recall_preempt()
            if userdata.stop_in_docking:
                pub_dock_cancel.publish(Bool(data=True))  # Cancel any active docking SMACH goals
                userdata.stop_in_docking = False
                rospy.loginfo('[{}]PREEMPTED_STOP -> reset (stop_in_docking)'.format(rospy.get_caller_id()))
                return 'reset'
            rospy.loginfo('[{}]PREEMPTED_STOP -> failure (will go to POWER_OFF_MOWER)'.format(rospy.get_caller_id()))
            return 'failure'

        smach.StateMachine.add('PREEMPTED_STOP', CBState(preempted_stop_cb),
                               {'failure': 'POWER_OFF_MOWER', 'reset': 'WAIT_FOR_PROGRAM'})

        # Add state POWER_OFF_MOWER
        @smach.cb_interface(input_keys=[], output_keys=[], outcomes=['success', 'failure'])
        def set_mower_off_cb(userdata):
            rospy.loginfo(
                '[{}]Setting mower off - state POWER_OFF_MOWER'.format(rospy.get_caller_id()))

            # Universal exit: ensure motor is off and blade is at max_height before
            # cutting power. Without this the FW auto-HOMEs on every preempted run
            # because PREEMPTED_STOP bypasses SET_MOTOR_OFF_AND_HOME.
            safe_blade_shutdown(source='POWER_OFF_MOWER')

            pub_mower_off = rospy.Publisher('/mower/set_power', Bool, latch=True, queue_size=1)
            msg = Bool()
            msg.data = False
            pub_status = pub_mower_off.publish(msg)
            rospy.loginfo('[{}]POWER_OFF_MOWER: published set_power(False)'.format(rospy.get_caller_id()))
            rospy.sleep(1.5)
            if pub_status is None:
                return 'success'

        smach.StateMachine.add('POWER_OFF_MOWER', CBState(set_mower_off_cb),
                               {'success': 'WAIT_MOWER_OFF', 'failure': 'POWER_OFF_MOWER'})

        # Bounded wait for /mower/status==OFF after power-off (timeout 30 s).
        class WaitForMowerOff(smach.State):
            def __init__(self, timeout=30.0):
                smach.State.__init__(self,
                                     outcomes=['off', 'timeout', 'preempted'],
                                     input_keys=['program', 'prg_start_time'],
                                     output_keys=['prg_start_time'])
                self.timeout = float(timeout)

            def execute(self, userdata):
                deadline = rospy.Time.now() + rospy.Duration(self.timeout)
                while not rospy.is_shutdown() and rospy.Time.now() < deadline:
                    if self.preempt_requested():
                        self.service_preempt()
                        return 'preempted'
                    try:
                        msg = rospy.wait_for_message('/mower/status', Mower, timeout=1.0)
                    except rospy.ROSException:
                        continue
                    if msg.status == 'OFF':
                        if userdata.prg_start_time is not None:
                            duration = (rospy.Time.now() - userdata.prg_start_time).to_sec() / 60
                            userdata.program.last_duration_minutes = int(round(duration))
                            save_prg_pub.publish(userdata.program)
                            userdata.prg_start_time = None
                        pub_active_prg.publish(String(" "))
                        pub_smach_status.publish(String("Ready"))
                        pub_log_info.publish(String("Done"))
                        return 'off'
                rospy.logwarn('[WAIT_MOWER_OFF] timeout (%.1fs); proceeding to dock anyway',
                              self.timeout)
                pub_active_prg.publish(String(" "))
                return 'timeout'

        smach.StateMachine.add('WAIT_MOWER_OFF', WaitForMowerOff(timeout=30.0),
                               transitions={
                                   'off': 'CHECK_FOR_DOCK_POINT',
                                   'timeout': 'CHECK_FOR_DOCK_POINT',
                                   'preempted': 'preempted'})
        
        ##########################################   DOCKING  ##########################################
        # Add state DOCKING check if DOCK point in the point list. if not, continue to WAIT_FOR_PROGRAM 
        # state. If yes, get the dock program and execute it. Then wait for the docked status and 
        # continue to WAIT_FOR_PROGRAM state.

        @smach.cb_interface(outcomes=['dock_point_found', 'no_dock_point', 'preempted'])
        def check_for_dock_point_cb(userdata):
            rospy.loginfo('[{}]Checking for DOCK point'.format(rospy.get_caller_id()))
            try:
                point_list_msg = rospy.wait_for_message('/navi_manager/map_point_str_list', StringList, timeout=5.0)
                if 'DOCK' in point_list_msg.string_list:
                    pub_log_info.publish(String("DOCK point found, starting docking sequence."))
                    return 'dock_point_found'
                else:
                    pub_log_info.publish(String("DOCK point not found, skipping docking."))
                    return 'no_dock_point'
            except rospy.ROSException:
                pub_log_info.publish(String("Could not get map point list."))
                return 'no_dock_point'

        smach.StateMachine.add('CHECK_FOR_DOCK_POINT', CBState(check_for_dock_point_cb),
                               transitions={'dock_point_found': 'GET_DOCK_PROGRAM',
                                            'no_dock_point': 'WAIT_FOR_PROGRAM',
                                            'preempted': 'PREEMPTED_STOP'})

        # Capture dock program (timeout-bounded).
        def _on_dock_program(userdata, msg):
            userdata.dock_program = msg
            pub_log_info.publish(String("Received dock program."))
            pub_smach_status.publish(String("Docking"))

        smach.StateMachine.add('GET_DOCK_PROGRAM',
                               WaitForTopic('/dock_manager/dock_program',
                                            DockProgram,
                                            predicate=lambda m: True,
                                            timeout=30.0,
                                            output_keys=['dock_program'],
                                            on_match=_on_dock_program),
                               transitions={'received': 'SEND_DOCK_PROGRAM',
                                            'timeout': 'WAIT_FOR_PROGRAM',
                                            'preempted': 'PREEMPTED_STOP'})

        @smach.cb_interface(input_keys=['dock_program'], outcomes=['succeeded'])
        def send_dock_program_cb(userdata):
            pub_dock = rospy.Publisher('/dock_smach/start_docking', DockProgram, queue_size=1, latch=True)
            pub_dock.publish(userdata.dock_program)
            pub_log_info.publish(String("Sent dock program."))
            rospy.sleep(1.0)
            return 'succeeded'

        smach.StateMachine.add('SEND_DOCK_PROGRAM', CBState(send_dock_program_cb),
                               transitions={'succeeded': 'WAIT_FOR_DOCKED'})

        class WaitForDockedState(smach.State):
            DOCK_TIMEOUT = 600.0  # 10 minutes hard cap; docking SMACH should retry internally.

            def __init__(self):
                smach.State.__init__(self, outcomes=['succeeded', 'failed', 'timeout', 'preempted'],
                                     input_keys=['stop_in_docking'],
                                     output_keys=['stop_in_docking'])
                self.pub_log_info = rospy.Publisher('/nextion/log_info', String, queue_size=10, latch=True)
                self.pub_smach_status = rospy.Publisher('/mower_smach/status', String, latch=True, queue_size=1)

            def execute(self, userdata):
                rospy.loginfo("Waiting for docked status (timeout %.0fs)...", self.DOCK_TIMEOUT)
                deadline = rospy.Time.now() + rospy.Duration(self.DOCK_TIMEOUT)
                while not rospy.is_shutdown() and rospy.Time.now() < deadline:
                    if self.preempt_requested():
                        userdata.stop_in_docking = True
                        rospy.logwarn("Docking sequence preempted by user.")
                        self.pub_log_info.publish(String("Docking preempted."))
                        self.service_preempt()
                        return 'preempted'

                    try:
                        msg = rospy.wait_for_message('/dock_smach/dock_status', Int8, timeout=1.0)
                        if msg.data == 0:  # Docked
                            self.pub_log_info.publish(String("Mower successfully docked."))
                            self.pub_smach_status.publish(String("Ready"))
                            return 'succeeded'
                        elif msg.data == 4:  # Failed
                            self.pub_log_info.publish(String("Docking failed."))
                            return 'failed'
                    except rospy.ROSException:
                        pass
                rospy.logwarn("WAIT_FOR_DOCKED timeout after %.0fs.", self.DOCK_TIMEOUT)
                self.pub_log_info.publish(String("Docking timed out."))
                return 'timeout'

        smach.StateMachine.add('WAIT_FOR_DOCKED',
                               WaitForDockedState(),
                               transitions={'succeeded': 'WAIT_FOR_PROGRAM',
                                            'failed': 'WAIT_FOR_PROGRAM',
                                            'timeout': 'WAIT_FOR_PROGRAM',
                                            'preempted': 'PREEMPTED_STOP'})


    # Create and start introspection server
    sis = smach_ros.IntrospectionServer('smach_server', sm, '/WAIT_FOR_PROGRAM')
    # sis = smach_ros.IntrospectionServer('smach_server', sm, '/CHECK_FOR_DOCK_POINT')
    sis.start()

    rospy.Timer(rospy.Duration(60), lambda event: periodic_save_callback(event, sm.userdata, save_prg_pub))

    def preempt_all_states():
        sm.request_preempt()
        zone_it.request_preempt()
        process_zone_sm.request_preempt()
        path_it.request_preempt()
        process_path_sm.request_preempt()

    def callback_stop(msg):
        if msg.data:
            preempt_all_states()

    
    
    def callback_pm_status(msg):
        if msg.battery_capacity <= 25 and sm.userdata.battery_capacity_checking:
            # Don't preempt while we are actively docking interrupting that
            # phase leaves the robot stranded outside the dock; let WAIT_FOR_DOCKED
            # finish and the next idle pass will refuse to start a new program
            # because battery_capacity_checking is now False.
            active = sm.get_active_states() if hasattr(sm, 'get_active_states') else []
            in_docking = any(s in ('WAIT_FOR_DOCKED', 'SEND_DOCK_PROGRAM', 'GET_DOCK_PROGRAM',
                                   'CHECK_FOR_DOCK_POINT', 'WAIT_MOWER_OFF', 'POWER_OFF_MOWER')
                             for s in active)
            if in_docking:
                rospy.logwarn(
                    "Battery <= 25%% but robot is in docking phase (%s); not preempting.",
                    active)
                return
            sm.userdata.battery_capacity_checking = False
            rospy.loginfo("Battery capacity <= 25 %, shutting down mower SMACH.")
            preempt_all_states()


    rospy.Subscriber("/mower_smach/stop", Bool, callback_stop)
    rospy.Subscriber("/pm/power_status", Power_status, callback_pm_status)

    def signal_handler(sig, frame):
        print("Shutting down...")
        rospy.signal_shutdown("end")
        sm.request_preempt()
        sis.stop()
        sis.clear()
        time.sleep(1)
        sys.exit(0)

    signal.signal(signal.SIGINT, signal_handler)

    sm.execute()
    rospy.spin()
    sis.stop()


if __name__ == "__main__":
    main()
